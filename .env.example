# ─── WooCommerce REST API ─────────────────────────────────────────────────────
# Your WordPress site URL (where WooCommerce is installed)
VITE_WC_BASE_URL=https://cms.yourdomain.com

# WooCommerce REST API keys — generate in WP Admin > WooCommerce > Settings > Advanced > REST API
# Set permissions to Read/Write
VITE_WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── WordPress REST API ───────────────────────────────────────────────────────
# Base WordPress REST API URL (usually same domain + /wp-json)
VITE_WP_API_URL=https://cms.yourdomain.com/wp-json

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Required plugin: "JWT Authentication for WP REST API"
# Plugin URL: https://wordpress.org/plugins/jwt-authentication-for-wp-rest-api/
# Add this to your WordPress wp-config.php:
#   define('JWT_AUTH_SECRET_KEY', 'your-super-secret-key');
#   define('JWT_AUTH_CORS_ENABLE', true);
VITE_WP_JWT_SECRET=your_jwt_secret_key_here
